BETTER_PROMPT_PROVIDER=gemini
BETTER_PROMPT_ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com
BETTER_PROMPT_MAX_PROMPT_LENGTH=2000
BETTER_PROMPT_RATE_LIMIT_MAX_REQUESTS=10
BETTER_PROMPT_RATE_LIMIT_WINDOW_SECONDS=60

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=20
GEMINI_RETRY_ATTEMPTS=1
GEMINI_MAX_OUTPUT_TOKENS=512
