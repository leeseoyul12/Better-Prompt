# OpenAI Responses API
BETTER_PROMPT_PROVIDER=openai
BETTER_PROMPT_ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com
BETTER_PROMPT_MAX_PROMPT_LENGTH=2000
BETTER_PROMPT_SAVED_PROMPT_MAX_LENGTH=6000
BETTER_PROMPT_RATE_LIMIT_MAX_REQUESTS=10
BETTER_PROMPT_RATE_LIMIT_WINDOW_SECONDS=60
BETTER_PROMPT_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/better_prompt
BETTER_PROMPT_SESSION_DURATION_DAYS=14
BETTER_PROMPT_GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=8
OPENAI_RETRY_ATTEMPTS=10
OPENAI_MAX_OUTPUT_TOKENS=1024
