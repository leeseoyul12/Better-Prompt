{
  "manifest_version": 3,
  "name": "Better Prompt",
  "version": "0.1.0",
  "description": "Adds a Better Prompt button to ChatGPT and connects to a configured FastAPI /improve API.",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "config.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
